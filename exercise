<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>English Practice - Submit Answers</title>
  <style>
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      background: #f8fafc;
      color: #334155;
      max-width: 700px;
      margin: 20px auto;
      padding: 15px;
    }
    h1 {
      color: #1e293b;
      text-align: center;
      margin-bottom: 30px;
    }
    form label {
      display: block;
      margin: 12px 0 6px 0;
      font-weight: 600;
    }
    input[type="text"] {
      width: 100%;
      font-size: 1em;
      padding: 8px 10px;
      border: 2px solid #3b82f6;
      border-radius: 6px;
      box-sizing: border-box;
    }
    button {
      margin-top: 25px;
      background: #3b82f6;
      color: white;
      font-weight: 700;
      font-size: 1.1em;
      border: none;
      border-radius: 8px;
      padding: 15px 0;
      width: 100%;
      cursor: pointer;
      transition: background-color 0.3s;
    }
    button:hover {
      background: #2563eb;
    }
    #result-message {
      margin-top: 20px;
      font-weight: 600;
      color: #10b981;
      text-align: center;
    }
  </style>
</head>
<body>
  <h1>English Practice - Submit Your Answers</h1>

  <form id="answer-form">
    <label for="student-name">Your Name (required)</label>
    <input type="text" id="student-name" name="studentName" placeholder="Enter your name" autocomplete="name" required />

    <div id="questions">
      <!-- 30题示例，这里演示前5题，后面你复制扩展即可 -->
      <label for="q1">1. What is economic degrowth?</label>
      <input type="text" id="q1" name="q1" placeholder="Type your answer here" required />

      <label for="q2">2. Why is degrowth important for the environment?</label>
      <input type="text" id="q2" name="q2" placeholder="Type your answer here" required />

      <label for="q3">3. What challenges arise with degrowth policies?</label>
      <input type="text" id="q3" name="q3" placeholder="Type your answer here" required />

      <label for="q4">4. How does degrowth relate to economic inequality?</label>
      <input type="text" id="q4" name="q4" placeholder="Type your answer here" required />

      <label for="q5">5. Can degrowth lead to more sustainable lifestyles?</label>
      <input type="text" id="q5" name="q5" placeholder="Type your answer here" required />

      <!-- 请继续依样画葫芦添加题目标签和输入框至 q30 -->
    </div>

    <button type="submit">Submit Answers</button>

    <div id="result-message"></div>
  </form>

  <script>
    const form = document.getElementById('answer-form');
    const resultMessage = document.getElementById('result-message');

    form.addEventListener('submit', function (event) {
      event.preventDefault();

      const formData = new FormData(form);

      fetch('https://formspree.io/f/your-form-id', { // <-- 替换成你Formspree的表单ID
        method: 'POST',
        body: formData,
        headers: {
          'Accept': 'application/json'
        }
      })
        .then(response => {
          if (response.ok) {
            resultMessage.style.color = '#10b981'; // 绿
            resultMessage.textContent = 'Thank you! Your answers have been submitted.';
            form.reset();
          } else {
            resultMessage.style.color = '#dc2626'; // 红
            resultMessage.textContent = 'Oops! Submission failed, please try again.';
          }
        })
        .catch(() => {
          resultMessage.style.color = '#dc2626';
          resultMessage.textContent = 'Network error! Please check your connection.';
        });
    });
  </script>
</body>
</html>
